{
  "manifest_version": 3,
  "name": "LinkScreen for LinkedIn",
  "version": "2.0",
  "description": "Detects visa sponsorship and eligibility in LinkedIn job posts. Screens roles by posting time, keywords, and sponsorship language.",
  "permissions": ["tabs", "storage", "webNavigation", "activeTab"],
  "host_permissions": ["*://*.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
